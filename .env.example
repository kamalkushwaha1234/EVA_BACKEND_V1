SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///eva.db
MQTT_BROKER_HOST=mqtt.eva.ai
MQTT_BROKER_PORT=8883
REDIS_URL=memory://

# Azure OpenAI (GPT-4.1 via GitHub Models)
GITHUB_TOKEN=your-github-token-here
AZURE_ENDPOINT=https://models.github.ai/inference
AZURE_MODEL=openai/gpt-4.1


# S3 (leave S3_BUCKET empty to use local file serving)
S3_BUCKET=eva-backend-audio
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Device bridge (bridge.py)
API_BASE=http://127.0.0.1:5000
BRIDGE_EMAIL=bridge@eva.ai
BRIDGE_PASSWORD=change-me
MQTT_USER=toy
MQTT_PASS=change-me
UDP_PORT=5005
